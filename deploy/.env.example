# Copy to .env in this directory on the VPS and fill in every value.
# Generate secrets with the commands shown; never reuse dev values.

# Image to run. After the GitHub repo exists this is
# ghcr.io/<github-username>/bw-ai-chat-api:latest
API_IMAGE=ghcr.io/accrane/bw-ai-chat-api:latest

# Subdomain Traefik should route to the chat API (A record -> VPS IP).
CHAT_DOMAIN=chat.bellaworksweb.com

# openssl rand -base64 24
POSTGRES_PASSWORD=

# openssl rand -base64 24  (password for the unprivileged app_api role)
APP_DB_PASSWORD=

# openssl rand -base64 48
SESSION_JWT_SECRET=

# openssl rand -base64 48
ADMIN_JWT_SECRET=

# openssl rand -base64 32  (encrypts client BYOK keys at rest)
SECRETS_KEY=

# Platform OpenAI key for embeddings + chat completions.
OPENAI_API_KEY=

LOG_LEVEL=info
