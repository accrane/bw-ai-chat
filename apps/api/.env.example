# Copy to .env for local development. Values below match the Supabase local
# stack started by `pnpm db:start`.

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Privileged connection: migrations, seed scripts, admin work. Never used to
# serve requests.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Unprivileged connection the API serves requests through (RLS enforced).
# The app_api role is granted LOGIN with this password by `pnpm db:role`.
APP_DATABASE_URL=postgresql://app_api:app_api_dev_password@127.0.0.1:54322/postgres
APP_DB_PASSWORD=app_api_dev_password

# HS256 secret for widget session JWTs. Min 32 chars; generate a real one for
# production: openssl rand -base64 48
SESSION_JWT_SECRET=dev-only-secret-0123456789abcdefghijklmnop

# Embeddings. Without a key, a deterministic fake provider is used (fine for
# local dev/tests; similarity becomes lexical overlap instead of semantic).
# OPENAI_API_KEY=sk-...
# EMBEDDINGS_PROVIDER=openai   # or "fake" to force offline mode
# LLM_PROVIDER=openai          # or "fake" for canned offline chat answers

# Required only when a client stores a BYOK OpenAI key (encrypted at rest).
# Generate: openssl rand -base64 32
# SECRETS_KEY=
